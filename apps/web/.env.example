# Copy to .env.local for local development.

# Backend API (Builder text chat, auth, etc.)
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Vapi voice (dashboard assistant — no custom LLM on this app)
# Create an assistant at https://dashboard.vapi.ai → use Public API key + Assistant ID.
# NEXT_PUBLIC_VAPI_PUBLIC_KEY=
# NEXT_PUBLIC_VAPI_ASSISTANT_ID=
