# Copy to .env and fill in values. Do not commit .env.

# OpenAI (official API) – optional; use for chat when CHAT_API_BASE_URL is unset
# OPENAI_API_KEY=sk-...

# Groq / OpenAI-compatible chat – optional
# CHAT_API_BASE_URL=https://api.groq.com/openai/v1
# CHAT_API_KEY=your_groq_api_key
# CHAT_MODEL=llama-3.3-70b-versatile

# Embeddings (OpenAI-compatible)
# EMBED_API_BASE_URL=...
# EMBED_API_KEY=...
# EMBED_MODEL=bge-base-en-v1.5

# Voice uses the Vapi dashboard assistant from the web app: set NEXT_PUBLIC_VAPI_PUBLIC_KEY and
# NEXT_PUBLIC_VAPI_ASSISTANT_ID in apps/web/.env.local (see apps/web/.env.example).
# Server-side transcript fetch by call id:
# VAPI_API_KEY=your_vapi_private_api_key
# Optional override:
# VAPI_API_BASE_URL=https://api.vapi.ai

# Database — include username and password for local PostgreSQL (driver defaults to OS user otherwise)
# Local: DATABASE_URL=postgresql://USERNAME:PASSWORD@localhost/conxa
# Example: DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/conxa
# For Render: use the External URL from the dashboard (internal host dpg-xxx is only resolvable on Render)

# Auth (change in production)
# JWT_SECRET=change-me-in-production
# AUTH_LOGIN_RATE_LIMIT=10/minute
# AUTH_SIGNUP_RATE_LIMIT=5/minute
# AUTH_VERIFY_RATE_LIMIT=10/minute

# OTP (Twilio Verify)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OTP_EXPIRE_MINUTES=10
# OTP_MAX_ATTEMPTS=5
# OTP_MAX_SENDS=5
# OTP_RESEND_COOLDOWN_SECONDS=30

# Email verification (SendGrid)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=no-reply@yourdomain.com
# SENDGRID_FROM_NAME=CONXA
# EMAIL_VERIFY_URL_BASE=https://your-web-app.com/verify-email
# EMAIL_VERIFY_EXPIRE_MINUTES=30
# EMAIL_VERIFICATION_REQUIRED=false

# Translation (for multi-language support)
# Option 1: Sarvam AI (India-focused, 23 languages, ₹1000 free credits on signup)
# Get API key from https://dashboard.sarvam.ai
# Same key is used for /speech/transcribe (home search voice) when SPEECH_TRANSCRIBE_PROVIDER=sarvam.
#TRANSLATION_PROVIDER=sarvam
#TRANSLATION_API_KEY=your_sarvam_api_key

# Search / home dictation via Deepgram (Nova) instead of Sarvam:
# SPEECH_TRANSCRIBE_PROVIDER=deepgram
# DEEPGRAM_API_KEY=your_deepgram_api_key
# Optional override (default nova-3):
# DEEPGRAM_MODEL=nova-3
# Home search uses WebSocket /speech/stream for live multilingual STT when provider is deepgram.

# Option 2: OpenAI-compatible LLM (any language, prompt-based)
# TRANSLATION_PROVIDER=openai
# TRANSLATION_API_BASE_URL=https://api.groq.com/openai/v1
# TRANSLATION_API_KEY=your_groq_api_key
# TRANSLATION_MODEL=llama-3.3-70b-versatile

# Public API URL for profile photo links (when behind proxy). Fallback: RENDER_EXTERNAL_URL on Render, else request.base_url.
# API_PUBLIC_URL=https://conxa-api.onrender.com

# CORS (comma-separated origins). With credentials, * is not allowed by browsers — set explicit origins in production.
# CORS_ORIGINS=*
# Example for production (e.g. Render): CORS_ORIGINS=https://conxa-web.onrender.com,https://your-app.onrender.com
