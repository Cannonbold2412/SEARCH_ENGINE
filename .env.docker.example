# Docker Compose environment file for local development
# Copy this file to .env in the root directory and fill in your values

# API Keys (required for LLM and embeddings)
CHAT_API_KEY=your_groq_api_key_here
EMBED_API_KEY=your_jina_api_key_here

# Optional: Override default models
# CHAT_MODEL=llama-3.3-70b-versatile
# EMBED_MODEL=jina-embeddings-v3

# Optional: Twilio for OTP
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: SendGrid for email verification
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=no-reply@yourdomain.com

# Optional: Vapi for voice
# NEXT_PUBLIC_VAPI_PUBLIC_KEY=your_vapi_public_key
# NEXT_PUBLIC_VAPI_ASSISTANT_ID=your_vapi_assistant_id
